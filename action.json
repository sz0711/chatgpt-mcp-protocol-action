{
  "openapi": "3.1.0",
  "info": {
    "title": "Microsoft Learn MCP (OpenAI-compatible)",
    "description": "Microsoft Learn MCP Server via JSON-RPC 2.0. Supports initialize, tools/list, tools/call.",
    "version": "v1.0.8"
  },
  "servers": [
    {
      "url": "https://learn.microsoft.com/api/mcp/openai-compatible"
    }
  ],
  "paths": {
    "/": {
      "post": {
        "operationId": "SendMcpMessage",
        "summary": "Send a JSON-RPC 2.0 request to MCP (initialize, tools/list, tools/call).",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/MCPRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "JSON-RPC 2.0 response (result or error).",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/JSONRPCResponse"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "RequestId": {
        "oneOf": [
          { "type": "string" },
          { "type": "integer" }
        ]
      },

      "MCPRequest": {
        "type": "object",
        "required": ["jsonrpc", "id", "method"],
        "properties": {
          "jsonrpc": {
            "type": "string",
            "enum": ["2.0"]
          },
          "id": {
            "$ref": "#/components/schemas/RequestId"
          },
          "method": {
            "type": "string",
            "enum": ["initialize", "tools/list", "tools/call"]
          },
          "params": {
            "type": "object",
            "description": "Params depend on method. initialize requires protocolVersion, clientInfo, capabilities. tools/call requires name and arguments.",
            "properties": {
              "protocolVersion": { "type": "string" },
              "clientInfo": {
                "type": "object",
                "properties": {
                  "name": { "type": "string" },
                  "version": { "type": "string" }
                },
                "required": ["name", "version"],
                "additionalProperties": true
              },
              "capabilities": {
                "type": "object",
                "properties": {},
                "additionalProperties": true
              },
              "name": { "type": "string" },
              "arguments": {
                "type": "object",
                "properties": {},
                "additionalProperties": true
              },
              "_meta": {
                "type": "object",
                "properties": {},
                "additionalProperties": true
              },
              "cursor": { "type": "string" }
            },
            "additionalProperties": true
          }
        },
        "additionalProperties": false,
        "description": "Single JSON-RPC request object. Note: method-specific required fields are validated by the MCP server."
      },

      "JSONRPCResponse": {
        "type": "object",
        "properties": {
          "jsonrpc": { "type": "string" },
          "id": { "$ref": "#/components/schemas/RequestId" },
          "result": {
            "type": "object",
            "properties": {},
            "additionalProperties": true
          },
          "error": { "$ref": "#/components/schemas/Error" }
        },
        "additionalProperties": true
      },

      "Error": {
        "type": "object",
        "required": ["code", "message"],
        "properties": {
          "code": { "type": "integer" },
          "message": { "type": "string" },
          "data": {}
        },
        "additionalProperties": true
      }
    }
  }
}
